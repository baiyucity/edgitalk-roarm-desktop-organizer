#define ROBOT_PLAN_JSON_SIZE      1536
#define ROBOT_CAMERA_MAX_WIDTH    424U
#define ROBOT_CAMERA_MAX_HEIGHT   240U
#define ROBOT_CAMERA_FRAME_BYTES  (ROBOT_CAMERA_MAX_WIDTH * ROBOT_CAMERA_MAX_HEIGHT * 2U)
#define ROBOT_CAMERA_ROW_MAX      (((ROBOT_CAMERA_MAX_WIDTH * 3U) + 3U) & ~3U)
#define ROBOT_CAMERA_PREVIEW_SCALE 1U

