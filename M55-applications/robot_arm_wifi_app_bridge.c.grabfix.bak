/*
 * Desktop Robot Arm APP bridge for RT-Thread.
 *
 * Purpose:
 * - Connect the board to a Wi-Fi router / phone hotspot as STA.
 * - Expose HTTP APIs used by the Flutter WebView / React APP.
 * - Keep the implementation independent from unfinished motion-control code.
 *
 * APP device address:
 *   http://<STA DHCP IP>
 *
 * Required RT-Thread components:
 * - WLAN management framework
 * - SAL / BSD socket API
 * - lwIP or another TCP/IP stack supported by SAL
 */

#include <rtthread.h>
#include <rtdevice.h>
#include <string.h>
#include <stdio.h>
#include <stdlib.h>

#include <sys/socket.h>
#include <netdb.h>
#include <netdev.h>
#include <netdev_ipaddr.h>

