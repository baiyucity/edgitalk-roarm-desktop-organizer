static void robot_http_server_thread(void *parameter)
{
    int server;
    struct sockaddr_in server_addr;

    RT_UNUSED(parameter);

    server = socket(AF_INET, SOCK_STREAM, 0);
    if (server < 0)
    {
        rt_kprintf("[robot] socket create failed\n");
        return;
    }

    memset(&server_addr, 0, sizeof(server_addr));
    server_addr.sin_family = AF_INET;
    server_addr.sin_addr.s_addr = htonl(INADDR_ANY);
    server_addr.sin_port = htons(ROBOT_HTTP_PORT);

    if (bind(server, (struct sockaddr *)&server_addr, sizeof(server_addr)) < 0)
    {
        rt_kprintf("[robot] bind port %d failed\n", ROBOT_HTTP_PORT);
        closesocket(server);
        return;
    }

    if (listen(server, 4) < 0)
    {
        rt_kprintf("[robot] listen failed\n");
        closesocket(server);
        return;
    }

    g_http_ready = RT_TRUE;
    rt_kprintf("[robot] HTTP server started on port %d\n", ROBOT_HTTP_PORT);
    rt_kprintf("[robot] HTTP server started. Use STA IP printed above.\n");
    while (1)
    {
        int client = accept(server, RT_NULL, RT_NULL);
        if (client >= 0)
        {
            rt_kprintf("[robot] HTTP client accepted\n");
            robot_handle_client(client);
        }
    }
}

