static int robot_wifi_start_ap(void)
{
    rt_kprintf("[robot] ERROR: AP FUNCTION SHOULD NOT RUN\n");
    return -RT_ERROR;
}
static int robot_wifi_start_sta(void)
{
    rt_err_t result;
    struct netdev *netdev;
    char ip[32] = "unknown";
    const char *if_name = ROBOT_WIFI_STA_IF;
    int i;

    rt_kprintf("[robot] connecting Wi-Fi STA: %s\n", ROBOT_WIFI_STA_SSID);

    result = rt_wlan_set_mode(if_name, RT_WLAN_STATION);
    if (result != RT_EOK)
    {
        rt_kprintf("[robot] set STA mode failed on %s: %d\n", if_name, result);
        return result;
    }

    result = rt_wlan_connect(ROBOT_WIFI_STA_SSID, ROBOT_WIFI_STA_PASSWORD);
    if (result != RT_EOK)
    {
        rt_kprintf("[robot] connect Wi-Fi returned warning: %d, continue to check IP\n", result);
    }
    else
    {
        rt_kprintf("[robot] connect Wi-Fi command accepted\n");
    }

    rt_kprintf("[robot] waiting for DHCP IP...\n");

    for (i = 0; i < 20; i++)
    {
        netdev = netdev_get_by_name("w0");
        if (!netdev)
        {
            netdev = netdev_get_by_name(if_name);
        }

        if (netdev)
        {
            if (!netdev_is_dhcp_enabled(netdev))
            {
                rt_kprintf("[robot] DHCP is disabled on %s, enabling...\n", netdev->name);
                (void)netdev_dhcp_enabled(netdev, RT_TRUE);
            }

            inet_ntoa_r(netdev->ip_addr, ip, sizeof(ip));

            rt_kprintf("[robot] DHCP check %d: ip=%s up=%d link=%d dhcp=%d\n",
                       i,
                       ip,
                       netdev_is_up(netdev),
                       netdev_is_link_up(netdev),
                       netdev_is_dhcp_enabled(netdev));

            if (strcmp(ip, "0.0.0.0") != 0 && strcmp(ip, "unknown") != 0)
            {
                rt_kprintf("[robot] STA IP: %s\n", ip);
                rt_kprintf("[robot] APP status URL: http://%s/status\n", ip);
                g_wifi_ready = RT_TRUE;
                return RT_EOK;
            }
        }
        else
        {
            rt_kprintf("[robot] STA netdev not found, waiting...\n");
        }

        rt_thread_mdelay(1000);
    }

    rt_kprintf("[robot] STA connected but no DHCP IP. Please check phone hotspot DHCP/client list.\n");
    return -RT_ERROR;
}
int robot_app_bridge_start(void)
{
    rt_thread_t tid;

    rt_kprintf("[robot] ===== NEW STA ENTRY =====\n");

    if (g_bridge_started)
    {
        rt_kprintf("[robot] bridge already started\n");
        return RT_EOK;
    }

    if (robot_wifi_start_sta() != RT_EOK)
    {
        return -RT_ERROR;
    }
    tid = rt_thread_create("robot_http",
                           robot_http_server_thread,
                           RT_NULL,
                           8192,
                           3,
                           10);
    if (tid)
    {
        rt_thread_startup(tid);
        g_bridge_started = RT_TRUE;
    }
    else
    {
        rt_kprintf("[robot] create HTTP thread failed\n");
        return -RT_ERROR;
    }

    return RT_EOK;
}
MSH_CMD_EXPORT(robot_app_bridge_start, start robot arm Wi-Fi STA and APP HTTP bridge);

static int robot_net_status(int argc, char **argv)
{
    RT_UNUSED(argc);
    RT_UNUSED(argv);

    rt_kprintf("[robot] ===== APP bridge status =====\n");
    rt_kprintf("[robot] bridge : %s\n", g_bridge_started ? "started" : "stopped");
    rt_kprintf("[robot] wifi   : %s\n", g_wifi_ready ? "ready" : "not ready");
    rt_kprintf("[robot] http   : %s\n", g_http_ready ? "ready" : "not ready");
    rt_kprintf("[robot] sta ssid: %s\n", ROBOT_WIFI_STA_SSID);
    rt_kprintf("[robot] sta if  : %s\n", ROBOT_WIFI_STA_IF);
    rt_kprintf("[robot] last   : %s\n", g_last_command);
    robot_print_netdev(ROBOT_WIFI_STA_IF);
    robot_print_netdev(ROBOT_NETDEV_AP_IF);
    if (strcmp(ROBOT_NETDEV_AP_IF, ROBOT_NETDEV_AP_IF_FALLBACK) != 0)
    {
        robot_print_netdev(ROBOT_NETDEV_AP_IF_FALLBACK);
    }
    rt_kprintf("[robot] =============================\n");

    return 0;
}
MSH_CMD_EXPORT(robot_net_status, show robot arm Wi-Fi and HTTP bridge status);

static void robot_app_bridge_auto_thread(void *parameter)
{
    RT_UNUSED(parameter);

    rt_thread_mdelay(5000);
    robot_app_bridge_start();
}

static int robot_app_bridge_auto_start(void)
{
    rt_thread_t tid;

    tid = rt_thread_create("robot_auto",
                           robot_app_bridge_auto_thread,
                           RT_NULL,
                           2048,
                           25,
                           10);
    if (tid)
    {
        rt_thread_startup(tid);
    }
    else
    {
        rt_kprintf("[robot] create auto-start thread failed\n");
    }

    return RT_EOK;
}
INIT_APP_EXPORT(robot_app_bridge_auto_start);
