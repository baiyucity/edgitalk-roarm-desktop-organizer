{
    edge_rc_frame_t frame;

    (void)argc;
    (void)argv;

    if (vision_ipc_open_once() != RT_EOK)
    {
        rt_kprintf("[M55 testtx] IPC open failed\r\n");
        return -RT_ERROR;
